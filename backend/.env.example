PORT=3001
SESSION_SECRET=change-me-in-production
CLIENT_ORIGIN=http://localhost:3000
NODE_ENV=development
# Redis session store (persistent). Set USE_REDIS=true to enable.
# Requires a running Redis instance. In production, the server exits if Redis is unavailable.
# Set USE_REDIS=false (or omit) to fall back to in-memory sessions (dev only).
USE_REDIS=true
REDIS_URL=redis://localhost:6379
